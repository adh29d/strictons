{
  "name": "@strictons/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/database.types.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push:dev": "supabase db push --db-url $SUPABASE_DB_URL_DEV --include-all",
    "db:push:prod": "supabase db push --db-url $SUPABASE_DB_URL_PROD --include-all",
    "db:diff:prod": "supabase db diff --db-url $SUPABASE_DB_URL_PROD --schema public",
    "db:test": "node ./scripts/run-pgtap.mjs",
    "db:seed": "tsx scripts/seed.ts",
    "gen:types": "supabase gen types typescript --local > src/database.types.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@strictons/config-eslint": "workspace:*",
    "@strictons/config-tsconfig": "workspace:*",
    "eslint": "^9.15.0",
    "supabase": "^1.226.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
